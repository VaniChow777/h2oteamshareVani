# Copy this file to a local-only env path such as:
# ~/.codex-secrets/sensors/webob.env
#
# Never commit real values.

SENSORS_AUTH_MODE=openapi
SENSORS_BASE_URL=https://your-sensors-private-deployment.example.com
SENSORS_PROJECT=your_project
SENSORS_OPENAPI_KEY=<your Sensors OpenAPI API Key, starts with #K->

# Optional. If unset, scripts derive the OpenAPI host from SENSORS_BASE_URL.
# SENSORS_OPENAPI_BASE_URL=http://your-sensors-openapi-host:8107
